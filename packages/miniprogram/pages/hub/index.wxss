/* pages/hub/index.wxss */

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--light-text-color);
  line-height: 1.5;
}

.category-title {
  font-size: 36rpx;
  font-weight: bold;
  margin: 20rpx 0 10rpx 0;
  color: var(--primary-color);
}

.history-section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-color);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--light-text-color);
}

.history-scroll {
  width: 100%;
  white-space: nowrap;
}

.history-list {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.history-card {
  display: inline-flex;
  flex-direction: column;
  width: 460rpx;
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  white-space: normal;
}

.history-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.history-meta {
  font-size: 24rpx;
  color: var(--light-text-color);
  margin-bottom: 10rpx;
}

.history-status {
  font-size: 24rpx;
  color: var(--primary-color);
  background-color: rgba(22, 119, 255, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  align-self: flex-start;
  margin-bottom: 14rpx;
}

.history-action {
  width: 100%;
  background-color: var(--primary-color);
  color: white;
  border-radius: 10rpx;
  font-size: 26rpx;
  line-height: 2.4;
}

.small-loading {
  padding: 24rpx;
}

.scenarios-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.scenario-card {
  background-color: var(--card-background);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  cursor: pointer;
  transition: all 0.3s;
}

.scenario-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.scenario-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.scenario-description {
  font-size: 28rpx;
  color: var(--light-text-color);
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.scenario-difficulty {
  font-size: 24rpx;
  color: var(--primary-color);
  background-color: rgba(22, 119, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 32rpx;
  color: var(--light-text-color);
}
