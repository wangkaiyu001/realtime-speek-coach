<!-- pages/practice/index.wxml -->
<view class="container">
  <view class="turn-indicator">
    第 {{turnCount}}/{{maxTurns}} 轮
  </view>

  <view class="status-text">{{statusText}}</view>

  <view class="retry-row" wx:if="{{canRetryTurn}}">
    <button class="button retry-button" bindtap="onTapRetryTurn">重试本轮</button>
  </view>

  <view class="chat-container">
    <view class="message {{item.roleClass}}" wx:for="{{chatMessages}}" wx:key="id">
      <view class="avatar">{{item.avatar}}</view>
      <view class="message-content">{{item.text}}</view>
    </view>
  </view>

  <!-- Hint Modal -->
  <view class="modal" wx:if="{{showHint}}">
    <view class="modal-content">
      <text class="modal-title">小提示</text>
      <text class="modal-text">{{hintText}}</text>
      <button class="button" bindtap="onTapHint">知道了</button>
    </view>
  </view>

  <!-- Controls -->
  <view class="controls">
    <button class="button hint-button" bindtap="onTapHint">
      提示
    </button>

    <button class="button record-button" bindtap="onTapRecord" disabled="{{recordDisabled}}">
      {{recordButtonText}}
    </button>

    <button class="button end-button" bindtap="onTapEndEarly">
      结束
    </button>
  </view>
</view>
