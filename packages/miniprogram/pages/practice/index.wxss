/* pages/practice/index.wxss */

.turn-indicator {
  text-align: center;
  font-size: 28rpx;
  color: var(--light-text-color);
  margin: 10rpx 0;
}

.chat-container {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.message {
  display: flex;
  max-width: 80%;
}

.ai-message {
  align-self: flex-start;
}

.user-message {
  align-self: flex-end;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 0 10rpx;
}

.message-content {
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  line-height: 1.5;
}

.ai-message .message-content {
  background-color: var(--card-background);
  border: 2rpx solid var(--border-color);
  border-top-left-radius: 4rpx;
}

.user-message .message-content {
  background-color: var(--primary-color);
  color: white;
  border-bottom-right-radius: 4rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.modal-text {
  font-size: 32rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.controls {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: white;
  border-top: 2rpx solid var(--border-color);
}

.hint-button,
.end-button {
  width: 25%;
  font-size: 28rpx;
  padding: 16rpx;
}

.record-button {
  width: 40%;
  background-color: var(--danger-color);
  font-size: 32rpx;
}

.record-button:hover {
  background-color: #ff7875;
}

.hint-button {
  background-color: var(--warning-color);
}

.hint-button:hover {
  background-color: #ffc53d;
}

.end-button {
  background-color: var(--light-text-color);
}

.end-button:hover {
  background-color: #8c8c8c;
}