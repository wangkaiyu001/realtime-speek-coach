{
  "name": "@rsc/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/server/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "prisma generate --schema ../../prisma/schema.sqlite.prisma && vitest run",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.sqlite.prisma",
    "db:push": "node ../../scripts/prisma-runtime.mjs db push --skip-generate",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:seed": "tsx src/db/seed.ts",
    "db:generate:local": "prisma generate --schema ../../prisma/schema.sqlite.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/websocket": "^11.0.0",
    "@prisma/client": "^5.22.0",
    "@rsc/contracts": "workspace:*",
    "@rsc/review": "workspace:*",
    "@rsc/voice": "workspace:*",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ws": "^8.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.0.0"
  }
}
