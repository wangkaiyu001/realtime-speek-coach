{
  "name": "@rsc/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@rsc/contracts": "workspace:*",
    "@rsc/voice": "workspace:*",
    "@rsc/review": "workspace:*",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ws": "^8.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.0.0"
  }
}
