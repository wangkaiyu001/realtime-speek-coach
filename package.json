{
  "name": "realtime-speak-coach",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @rsc/server dev",
    "dev:voice": "pnpm --filter @rsc/voice dev",
    "smoke:mock-e2e": "node scripts/mock-e2e-smoke.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@prisma/client": "5",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.4.0",
    "prisma": "5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
