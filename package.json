{
  "name": "realtime-speak-coach",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "pnpm -r test",
    "build": "pnpm --filter @rsc/server db:generate && pnpm -r build",
    "dev:server": "pnpm --filter @rsc/server dev",
    "dev:voice": "pnpm --filter @rsc/voice dev",
    "smoke:mock-e2e": "node scripts/mock-e2e-smoke.mjs",
    "prepare": "husky",
    "verify:public": "node scripts/verify-public-release.mjs",
    "verify:miniprogram": "node scripts/verify-miniprogram-release.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "audit:go-live": "node scripts/go-live-audit.mjs",
    "miniprogram:preview": "node scripts/upload-miniprogram.mjs preview",
    "miniprogram:upload": "node scripts/upload-miniprogram.mjs upload"
  },
  "devDependencies": {
    "@prisma/client": "5",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "miniprogram-ci": "^2.1.31",
    "prettier": "^3.4.0",
    "prisma": "5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
