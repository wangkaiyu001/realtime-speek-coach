// Prisma Schema - Realtime Speak Coach
// CloudBase MySQL in production; local development uses a dedicated SQLite schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid()) @db.VarChar(32)
  openId    String   @unique @map("open_id") @db.VarChar(191)
  unionId   String?  @map("union_id") @db.VarChar(191)
  language  String?  @db.VarChar(8) // 'en' | 'ja', null until chosen
  level     Int? // 1-9 proficiency
  nickname  String?  @db.VarChar(191)
  avatarUrl String?  @map("avatar_url") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  placementResults PlacementResult[]
  sessions         Session[]

  @@map("echoia_users")
}

model PlacementResult {
  id            String   @id @default(cuid()) @db.VarChar(32)
  userId        String   @map("user_id") @db.VarChar(32)
  language      String   @db.VarChar(8) // 'en' | 'ja'
  level         Int // resulting level 1-9
  pronunciation Int      @default(0) // 0-100
  grammar       Int      @default(0)
  vocabulary    Int      @default(0)
  fluency       Int      @default(0)
  interaction   Int      @default(0)
  rawData       String?  @map("raw_data") @db.LongText // JSON string of full assessment
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("echoia_placement_results")
}

model Session {
  id             String   @id @default(cuid()) @db.VarChar(32)
  userId         String   @map("user_id") @db.VarChar(32)
  scenarioId     String   @map("scenario_id") @db.VarChar(191)
  language       String   @db.VarChar(8)
  level          Int
  totalTurns     Int      @default(10) @map("total_turns")
  turnsCompleted Int      @default(0) @map("turns_completed")
  status         String   @default("in_progress") @db.VarChar(32) // in_progress | completed | abandoned
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  turns  Turn[]
  review Review?

  @@map("echoia_sessions")
}

model Turn {
  id           String   @id @default(cuid()) @db.VarChar(32)
  sessionId    String   @map("session_id") @db.VarChar(32)
  turnIndex    Int      @map("turn_index")
  userText     String?  @map("user_text") @db.LongText
  aiText       String?  @map("ai_text") @db.LongText
  userAudioUrl String?  @map("user_audio_url") @db.VarChar(1024)
  aiAudioUrl   String?  @map("ai_audio_url") @db.VarChar(1024)
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, turnIndex])
  @@map("echoia_turns")
}

model Review {
  id             String    @id @default(cuid()) @db.VarChar(32)
  sessionId      String    @unique @map("session_id") @db.VarChar(32)
  status         String    @default("pending") @db.VarChar(32) // pending | processing | completed | failed
  pronunciation  Int?
  grammar        Int?
  vocabulary     Int?
  fluency        Int?
  interaction    Int?
  overallComment String?   @map("overall_comment") @db.LongText
  highlights     String?   @db.LongText // JSON array
  suggestions    String?   @db.LongText // JSON array
  corrections    String?   @db.LongText // JSON array of TurnCorrection
  rawResponse    String?   @map("raw_response") @db.LongText // Full LLM response
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("echoia_reviews")
}
