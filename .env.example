# ============================================================
# Realtime Speak Coach - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
WS_PORT=3001
MOCK=1
CORS_ORIGIN=*

# Set MOCK=1 to mock the whole app locally, or keep MOCK=0 and enable only the
# blocked pieces below. This supports mock login + mock voice + real LLM.
MOCK_AUTH=1
MOCK_VOICE=1
MOCK_LLM=1
MOCK_REVIEW=1

# --- JWT ---
JWT_SECRET=change-me-in-production

# --- WeChat Mini Program ---
WX_APP_ID=wxTESTAPPID
WX_APP_SECRET=your_wx_app_secret_here

# --- DeepSeek ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Gemini (Fallback) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Volcengine Doubao Voice (新版流式语音) ---
VOLC_VOICE_API_KEY=your_volcengine_access_key_here
VOLC_VOICE_APP_KEY=your_volcengine_app_key_here
VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
VOLC_TTS_WS_URL=wss://openspeech.bytedance.com/api/v3/tts/bidirection
VOLC_TTS_RESOURCE_ID=seed-tts-1.0
VOLC_TTS_MODEL=seed-tts-1.1
VOLC_TTS_VOICE_EN=en_female_amanda_mars_bigtts
VOLC_TTS_VOICE_JA=multi_female_shuangkuaisisi_moon_bigtts
VOLC_TTS_FORMAT=mp3
VOLC_TTS_SAMPLE_RATE=24000

# --- Database ---
# Local development uses prisma/schema.sqlite.prisma automatically.
DATABASE_URL=file:./prisma/dev.db

# --- CloudBase Cloud Run MVP public trial ---
# Configure these in the CloudBase console for the echoia-server service.
# Keep login mocked until the mini program is registered/filed.
# DATABASE_URL must point to shared CloudBase MySQL in production.
# Replace JWT_SECRET with a long random value.
# NODE_ENV=production
# HOST=0.0.0.0
# PORT=3000
# Production must use the shared CloudBase MySQL database. A container-local
# SQLite file is not safe when Cloud Run serves requests from multiple pods.
# DATABASE_URL=mysql://echoia_app:<password>@<private-ip>:3306/<database>
# DATABASE_PUSH_ON_START=0
# JWT_SECRET=replace-with-a-long-random-secret
# MOCK=1
# MOCK_AUTH=1
# MOCK_VOICE=1
# MOCK_LLM=1
# MOCK_REVIEW=1
# CORS_ORIGIN=*
