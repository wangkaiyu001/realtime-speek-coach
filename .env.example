# ============================================================
# Realtime Speak Coach - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
WS_PORT=3001
MOCK=1

# --- JWT ---
JWT_SECRET=change-me-in-production

# --- WeChat Mini Program ---
WX_APP_ID=wxTESTAPPID
WX_APP_SECRET=your_wx_app_secret_here

# --- DeepSeek ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Gemini (Fallback) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Volcengine Doubao Voice (新版流式语音) ---
VOLC_VOICE_API_KEY=your_volcengine_voice_api_key_here
VOLC_VOICE_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel

# --- Database ---
DATABASE_URL=file:../prisma/dev.db
